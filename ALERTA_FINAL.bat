@echo off
:: Inicia o PowerShell de forma totalmente escondida
start /min powershell.exe -WindowStyle Hidden -ExecutionPolicy Bypass -Command "$wshell = New-Object -ComObject WScript.Shell; $lastAlert = Get-Date; while($true) { $p = Get-Process | Where-Object { ($_.Name -match 'olk|outlook') -and ($_.MainWindowTitle -ne '') } | Select-Object -First 1; if($p) { $title = $p.MainWindowTitle; if($title -match 'Caixa de Entrada' -or $title -match '\(\d+\)') { if ((Get-Date) -gt $lastAlert.AddMinutes(1)) { $wshell.Popup('ATENCAO: Voce tem e-mails pendentes no Outlook!', 0, 'Alerta de E-mail', 4096+48); $lastAlert = Get-Date; } } } Start-Sleep -Seconds 10; }"
